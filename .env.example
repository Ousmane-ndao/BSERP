# URL de l’API Laravel (doit se terminer par /api). En dev, vous pouvez laisser vide :
# les appels iront sur /api et Vite (port 8080) les proxifie vers http://127.0.0.1:8000.
# Ne pas mettre http://localhost:8080 seul (sinon le login part sur :8080/login → 404).
# VITE_API_URL=
VITE_API_URL=http://127.0.0.1:8000/api
# Affichage (optionnel, défaut XOF / FCFA)
# VITE_CURRENCY_CODE=XOF
# VITE_CURRENCY_LABEL=FCFA
